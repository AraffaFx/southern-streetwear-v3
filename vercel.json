{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "routes": [
    {
      "src": "/(.*\\.(css|js|jpg|jpeg|png|gif|svg|ico|webp))",
      "dest": "/$1"
    },
    {
      "src": "/cerita-kami/(.*\\.(css|js|jpg|jpeg|png|gif|svg|ico|webp))",
      "dest": "/cerita-kami/$1"
    },
    {
      "src": "/kontak/(.*\\.(css|js))",
      "dest": "/kontak/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}